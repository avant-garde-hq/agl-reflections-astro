---
// APEX 5040 interactive 3D concept demo -- source:
// agl-reflections-website/stages/apex-5040-3d.html (34 lines). Deliberately
// bare: no site nav/header/footer, just a `<model-viewer>` element spinning
// a rough massing model. Reuses Layout for the `<head>`/meta plumbing
// (noindex, fonts, tokens) since that's cleaner than hand-rolling a second
// `<head>`, but nothing from house/Header or house/Footer is rendered --
// matching the source's intentionally minimal chrome. The sitemap filter
// (astro.config.mjs, Task 1) already excludes any URL containing
// "apex-5040-3d", on top of this page's own noindex meta.
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="APEX 5040 — Interactive 3D Concept | Reflections Productions"
  description="Interactive 3D massing model of the APEX 5040 — the flagship 50-by-40 hydraulic mobile stage. Concept demo, not for production reference."
  path="/stages/apex-5040-3d.html"
  noindex
>
  <script type="module" src="/assets/js/model-viewer.min.js" is:inline></script>

  <header>
    <h1><span class="bars" aria-hidden="true"><i></i><i></i><i></i></span>APEX 5040 <span>&middot; Interactive 3D</span></h1>
    <span class="tag">CONCEPT DEMO — MASSING MODEL</span>
  </header>

  <model-viewer
    src="/assets/apex-5040-massing.glb"
    alt="Interactive 3D massing model of the APEX 5040 mobile stage"
    camera-controls
    auto-rotate
    auto-rotate-delay="800"
    rotation-per-second="18deg"
    shadow-intensity="0.9"
    exposure="1.25"
    camera-orbit="205deg 75deg 125m"
    min-camera-orbit="auto auto 60m"
    max-camera-orbit="auto auto 240m"
  ></model-viewer>

  <footer>
    <p><b>Drag to spin &middot; scroll to zoom.</b> Rough massing proportions of the 50′ × 40′ flagship — deck, mast columns, roof, fly bays and outriggers.</p>
    <p>Production version: photoreal model from manufacturer CAD, embedded on every stage page.</p>
  </footer>
</Layout>

<style>
  :global(body) {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  header {
    padding: 26px 5vw 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 34px);
    letter-spacing: 0.01em;
  }
  h1 span {
    color: var(--glow-teal);
  }
  .tag {
    font: 600 11px/1 var(--font-body);
    letter-spacing: 0.16em;
    color: var(--gel-coral);
    border: 1px dashed rgba(255, 107, 74, 0.5);
    padding: 7px 10px;
  }
  model-viewer {
    width: 100%;
    flex: 1;
    min-height: 66vh;
    background:
      radial-gradient(ellipse at 50% 80%, rgba(19, 94, 84, 0.35), transparent 60%),
      var(--ink);
    --poster-color: transparent;
  }
  footer {
    padding: 16px 5vw 26px;
    display: flex;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 12.5px;
    color: rgba(244, 239, 230, 0.55);
    line-height: 1.6;
  }
  footer b {
    color: var(--paper);
  }
  .bars {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    margin-right: 10px;
    vertical-align: middle;
  }
  .bars i {
    display: block;
    height: 3px;
    background: var(--glow-teal);
  }
  .bars i:nth-child(1) {
    width: 26px;
  }
  .bars i:nth-child(2) {
    width: 19px;
    opacity: 0.7;
  }
  .bars i:nth-child(3) {
    width: 12px;
    opacity: 0.4;
  }
</style>
