---
// Work / case-studies index. Composes Layout/Header/PageHero around ALL 6
// source work items (WorkItem, full mode) plus the source's own "From the
// Road" photo gallery and QuoteCta/Footer. Ported from
// agl-reflections-website/work/index.html (301 lines).
//
// TASK 20 COMPLETENESS FIX: this page originally rendered only the 4 items
// that have a dedicated case-study page, in WorkItem's compact `teaser` mode
// (photo wrapped in a link, one-line subtitle, no deploy list). That was
// wrong on two counts, confirmed against source lines 95-189:
//   1. Source has 6 work-item blocks on this page, not 4 -- it also includes
//      "Formula E Fan Village" (lines 127-141) and "Network Broadcast Sets"
//      (lines 175-189), which exist ONLY on this index page (no dedicated
//      case-study page/href anywhere in the source site).
//   2. ALL 6 items on this page use the richer format WorkItem's `full` mode
//      renders (event-meta, heading, full prose body, 4-item deploy list) --
//      never the homepage's compact `teaser` mode, and the photo is never
//      wrapped in a link here. Only the 4 items with a real case-study page
//      additionally get a "Read the full story" arrow-link below the deploy
//      list (source lines 107/123/155/171) -- Formula E and Network
//      Broadcast Sets have no such link (no page to link to).
// WorkItem gained an optional `readMoreHref` prop (full mode only) to render
// that conditional link; left undefined it renders nothing, so the 4
// case-study pages (Task 20, unchanged) and the homepage's `teaser` mode
// (Task 14, unchanged) are unaffected.
//
// IMPORTANT DISCOVERY (beyond what the fix brief assumed): none of the 6
// items on this page reuse `src/data/work.ts`'s WORK records. WORK's
// eventMeta/body/deployList/heroImage were transcribed from the 4 DEDICATED
// case-study pages (work/hialeah-4th-of-july.html etc., Task 10) -- longer
// body copy, a different (6-item, for Hialeah) deploy list, and for
// FloydFest/Mobile Stage Conference a *different hero image entirely*
// (stage-2424-hero.webp / stage-5040-hero.webp here, vs. a reused gallery
// photo on the case-study page, since those two case-study pages have no
// unique hero photo of their own). This index page has its own shorter,
// punchier teaser copy for the same 4 events, verified against source lines
// 95-173. So all 6 items below are page-local objects transcribed straight
// from THIS page's own source markup, not derived from WORK at all --
// `readMoreHref` is the only place this page still points at the 4 real
// case-study routes (as plain literal hrefs, matching source's own
// same-directory relative links translated to absolute site paths).
//
// Formula E Fan Village and Network Broadcast Sets are additionally never
// added to the shared WORK array in src/data/work.ts (same reasoning as
// the other 4 above, plus): WORK's 4 entries are looked up by slug from 4
// real case-study pages (`WORK.find(w => w.slug === ...)`), so adding fake
// entries there risks a future task treating them as real case studies
// (e.g. generating a teaser link or a `/work/<slug>.html` page) since
// nothing stops WorkCase's `slug` field being used as a real route slug.
// Page-local data makes that misuse impossible by construction.
//
// The per-item `flip` value alternates false/true/false/true/false/true in
// source order, matching each block's own `class="work-item flip"` (or its
// absence) in source lines 95/111/127/143/159/175.
//
// The "From the Road" gallery (source lines 195-206) is real content beyond
// the case links -- 13 real photos with real per-tile captions (data-cap)
// and 3 "wide" tiles, all already available as local image assets.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/house/Header.astro';
import Footer from '../../components/house/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import WorkItem from '../../components/WorkItem.astro';
import Gallery from '../../components/Gallery.astro';
import QuoteCta from '../../components/QuoteCta.astro';
import Kicker from '../../components/ui/Kicker.astro';
import type { WorkCase } from '../../data/work';

import workCrowd from '../../assets/img/work-crowd.webp';
import workHialeah from '../../assets/img/work-hialeah.webp';
import workBigorange from '../../assets/img/work-bigorange.webp';
import stage2016Hero from '../../assets/img/stage-2016-hero.webp';
import stage2424Hero from '../../assets/img/stage-2424-hero.webp';
import stage5040Hero from '../../assets/img/stage-5040-hero.webp';
import stage3224Hero from '../../assets/img/stage-3224-hero.webp';
import galCapitol from '../../assets/img/gal-capitol.webp';
import galApexCrowd from '../../assets/img/gal-apex-crowd.webp';
import galLukebryan from '../../assets/img/gal-lukebryan.webp';
import galLasers from '../../assets/img/gal-lasers.webp';
import gal4240night from '../../assets/img/gal-4240night.webp';
import stage4240Hero from '../../assets/img/stage-4240-hero.webp';
import svcVideo from '../../assets/img/svc-video.webp';
import galBuild from '../../assets/img/gal-build.webp';
import galTruck from '../../assets/img/gal-truck.webp';
import stage4240B from '../../assets/img/stage-4240-b.webp';
import fleetVip3724 from '../../assets/img/fleet-vip-3724.webp';
import galStudio from '../../assets/img/gal-studio.webp';

// All 6 objects are page-local, transcribed verbatim from
// agl-reflections-website/work/index.html lines 95-189 -- see the note
// above for why none of them read from the shared WORK array. `subtitle`
// and `gallery` are unused by WorkItem in full mode; included only to
// satisfy the WorkCase type. `slug` is likewise unused by full mode -- for
// the 4 real events it's set to the real case-study slug anyway (harmless);
// for the 2 with no case-study page it's a placeholder that must never be
// used to generate a link or page.
const hialeahCase: WorkCase = {
  slug: 'hialeah-4th-of-july',
  title: 'Hialeah<br /><em>4th of July</em>',
  subtitle: '',
  eventMeta: 'Milander Park, Hialeah · July 4',
  heroImage: workHialeah,
  heroImageAlt: 'Fireworks bursting around the APEX stage at the Hialeah 4th of July celebration',
  body: "<p>The City of Hialeah's Independence Day celebration draws thousands to Milander Park — headlined by Cuban reggaeton duo Gente de Zona, closed by one of the biggest fireworks shows in the state. Reflections handled the production end to end, load-in to strike, coordinating artists, city officials and vendors.</p>",
  deployList: [
    'APEX GEN3 hydraulic mobile stage',
    'Full JBL concert audio, FOH &amp; monitors',
    'Intelligent lighting rig, designed &amp; operated',
    'Show power, barriers &amp; site logistics',
  ],
  gallery: [],
};

const bigOrangeCase: WorkCase = {
  slug: 'big-orange-nye',
  title: 'Big Orange<br /><em>NYE Miami</em>',
  subtitle: '',
  eventMeta: 'Bayfront Park, Miami · Dec 31',
  heroImage: workBigorange,
  heroImageAlt: "The Big Orange New Year's Eve stage at Bayfront Park with LED video walls",
  body: "<p>Miami's answer to the ball drop: the 35-foot Big Orange climbing the InterContinental as tens of thousands count down at Bayfront Park. The free Countdown Miami festival has carried names like Marshmello, Nicky Jam, Flo Rida, Gente de Zona and To&ntilde;o Rosario — with Reflections building the show beneath them.</p>",
  deployList: [
    'Reflections mobile staging',
    'LED video walls, live camera feeds &amp; switching',
    'Concert audio &amp; lighting through midnight',
    'Full production &amp; crew, into the new year',
  ],
  gallery: [],
};

