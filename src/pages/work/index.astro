  slug: 'formula-e-fan-village',
  title: 'Formula E<br /><em>Fan Village</em>',
  subtitle: '',
  eventMeta: 'Miami E-Prix · 2025 Season',
  heroImage: stage2016Hero,
  heroImageAlt: 'APEX 2016 stage dressed as the Formula E Fan Village stage at the 2025 Miami E-Prix',
  body: '<p>When the ABB FIA Formula E World Championship came to Miami, the Fan Village stage was an APEX 2016 — wrapped edge to edge in a custom branded arch package, with an LED screen running race-day content and JBL sound covering the village.</p>',
  deployList: [
    'APEX 2016 mobile stage, custom-branded',
    'Full-width LED video screen',
    'JBL sound system for the fan village',
    'Compact footprint on a tight race-campus site',
  ],
  gallery: [],
};

const floydfestCase: WorkCase = {
  slug: 'floydfest',
  title: 'Floyd<em>Fest</em>',
  subtitle: '',
  eventMeta: 'Floyd, Virginia · Festival Season',
  heroImage: stage2424Hero,
  heroImageAlt: 'APEX GEN3 stage and APEX 2424 running side by side on the festival lawn at FloydFest',
  body: '<p>Proof the Princeton yard travels: two APEX stages rolled up the Blue Ridge for FloydFest — a GEN3 and the 2424 side by side on the festival lawn, running alternating sets so the music never stopped between changeovers.</p>',
  deployList: [
    'APEX GEN3 + APEX 2424, dual-stage build',
    'LED walls &amp; lighting on both decks',
    'Back-to-back changeovers, zero dead air',
    'Long-haul trucking &amp; tour logistics',
  ],
  gallery: [],
};

const mscCase: WorkCase = {
  slug: 'mobile-stage-conference-2023',
  title: "Mobile Stage<br /><em>Conference '23</em>",
  subtitle: '',
  eventMeta: 'Bahia Mar, Fort Lauderdale · Feb 7–9, 2023',
  heroImage: stage5040Hero,
  heroImageAlt: 'APEX 5040 GEN3 stage built out with line arrays and video wall',
  body: '<p>The largest mobile-stage networking event of the year, and Reflections was at the center of it — three days of training on sales, rentals and safety at the Bahia Mar Hotel, where the APEX 5040 GEN3 turned heads for its structural integrity and lightning-fast deployment.</p>',
  deployList: [
    'APEX 5040 GEN3 showcase build',
    'Walk-the-deck rigging &amp; outrigger demos',
    'Safety, DOT &amp; certification forums',
    'Feb 7&ndash;9, 2023 &middot; Fort Lauderdale, FL',
  ],
  gallery: [],
};

const networkBroadcastCase: WorkCase = {
  slug: 'network-broadcast-sets',
  title: 'Network<br /><em>Broadcast Sets</em>',
  subtitle: '',
  eventMeta: 'Nationwide · Live Broadcast',
  heroImage: stage3224Hero,
  heroImageAlt: 'APEX 3224 stage configured as a broadcast-ready live set',
  body: '<p>The setup used by ESPN nationwide for College GameDays: our APEX 3224 is the same stage the major sports networks use for their &ldquo;live on the scene&rdquo; sets — auto racing, horse racing and college football — placed and broadcast-ready within 30 minutes, roof at variable heights.</p>',
  deployList: [
    'APEX 3224 broadcast-set configuration',
    '&ldquo;MyPad&rdquo; remote studio &amp; control room',
    'HD cameras, grips &amp; operators',
    'Set in 30 minutes, roof at variable trim',
  ],
  gallery: [],
};

const roadGallery = [
  { image: galCapitol, alt: 'Civic stage build at the state capitol', caption: 'Civic Main Stage' },
  { image: galApexCrowd, alt: 'APEX stage and LED wall in front of a packed crowd', caption: 'Festival Front Row', wide: true },
  { image: galLukebryan, alt: 'Country headliner stage built with dual screens', caption: 'Country Headliner' },
  { image: workCrowd, alt: 'Crowd under a halo of light at a night concert', caption: 'The Front Row', wide: true },
  { image: galLasers, alt: 'Lasers cutting through haze during a production', caption: 'Laser & FX Show' },
  { image: gal4240night, alt: 'APEX 4240 GEN3 at night with LED walls and a full festival crowd', caption: 'GEN3 After Dark' },
  { image: stage4240Hero, alt: 'APEX 4240 stage built at a fairground beside a ferris wheel', caption: 'Fair Midway' },
  { image: svcVideo, alt: 'LED video columns glowing orange at the Hialeah build', caption: 'Hialeah in Orange' },
  { image: galBuild, alt: 'APEX GEN3 stages mid-build at a waterfront site', caption: 'GEN3 Load-In' },
  { image: galTruck, alt: 'Reflections production truck arriving at a stadium event', caption: 'On the Road' },
  { image: stage4240B, alt: 'APEX 4240 mobile stage deployed directly on the beach', caption: 'Beach Build', wide: true },
  { image: fleetVip3724, alt: "Captain's VIP Deck 3724 raised at an event site", caption: "Captain's VIP Deck" },
  { image: galStudio, alt: 'The Reflections recording and production studio', caption: 'Back at the Shop' },
