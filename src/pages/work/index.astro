---

<Layout
  title="Our Work — Hialeah 4th of July, Big Orange NYE, Formula E & More | Reflections Productions"
  description="Case studies from Reflections Productions: the Hialeah 4th of July, Miami's Big Orange NYE at Bayfront Park, the Formula E Fan Village at the Miami E-Prix, FloydFest, the Mobile Stage Conference and network broadcast sets — stages, audio, lighting and video."
  path="/work/"
  ogImage="https://reflectionsproductions.com/assets/img/work-hialeah.webp"
>
  <Header currentPath="/work/index.html" />

  <PageHero
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Our Work' }]}
    eyebrow="Our Work · Fifty Seasons of Shows"
    title={['Nights the City', 'Remembers']}
    lede="From Independence Day fireworks to the New Year's countdown, Reflections stages carry South Florida's signature celebrations. <b>Here's what that looks like.</b>"
    imageSrc={workCrowd}
    imageAlt="Concert crowd under a ring of light at a Reflections production"
  />

  <section class="band tight">
    <div class="wrap">
      <WorkItem case={hialeahCase} readMoreHref="/work/hialeah-4th-of-july.html" heroImagePosition="center 72%" />
      <WorkItem case={bigOrangeCase} flip readMoreHref="/work/big-orange-nye.html" />
      <WorkItem case={formulaECase} />
      <WorkItem case={floydfestCase} flip readMoreHref="/work/floydfest.html" />
      <WorkItem case={mscCase} readMoreHref="/work/mobile-stage-conference-2023.html" />
      <WorkItem case={networkBroadcastCase} flip />
    </div>
  </section>

  <div class="divider wrap" aria-hidden="true"><span class="bars"><i></i><i></i><i></i></span></div>

  <section class="band">
    <div class="wrap">
      <div class="sec-head">
        <div class="left rv">
          <Kicker text="Gallery" />
          <h2>From the<br /><span class="ghost">Road</span></h2>
        </div>
        <p class="right">Fifty years produces a lot of nights. A few more of them — builds, front rows and the miles in between.</p>
      </div>
      <Gallery items={roadGallery} />
    </div>
  </section>

  <QuoteCta compact />

  <Footer />
</Layout>
