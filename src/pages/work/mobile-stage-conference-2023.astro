---
// Case study: Mobile Stage Conference 2023. Composes Layout/Header/PageHero/
// full-mode WorkItem/Gallery/QuoteCta/Footer around the
// "mobile-stage-conference-2023" WORK record (Task 10). Ported from
// agl-reflections-website/work/mobile-stage-conference-2023.html (229
// lines). This case study has no video section in the source.
//
// Real content beyond the brief's "WorkItem + Gallery" summary: the
// source's own prev/next case-study nav row ("FloydFest" -> this page ->
// "All case studies" (index)), transcribed as-is.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/house/Header.astro';
import Footer from '../../components/house/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import WorkItem from '../../components/WorkItem.astro';
import Gallery from '../../components/Gallery.astro';
import QuoteCta from '../../components/QuoteCta.astro';
import Kicker from '../../components/ui/Kicker.astro';
import { WORK } from '../../data/work';

const item = WORK.find((w) => w.slug === 'mobile-stage-conference-2023')!;
---

<Layout
  title="Case Study: Mobile Stage Conference 2023 — APEX 5040 GEN3 Showcase | Reflections Productions"
  description="At the Mobile Stage Conference 2023 in Las Vegas, the APEX 5040 GEN3 headlined the industry's product showcase — Reflections Productions among the top minds in mobile staging."
  path="/work/mobile-stage-conference-2023.html"
  ogImage="https://reflectionsproductions.com/assets/img/work-hialeah.webp"
>
  <Header currentPath="/work/index.html" />

  <PageHero
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Our Work', href: '/work/index.html' }, { label: item.eventMeta }]}
    eyebrow={`Case Study · ${item.eventMeta}`}
    title={['Innovation', 'On Wheels']}
    lede={item.subtitle}
    imageSrc={item.heroImage}
    imageAlt={item.heroImageAlt}
  />

  <section class="band tight">
    <div class="wrap">
      <WorkItem case={item} />
    </div>
  </section>

  <section class="band tight">
    <div class="wrap">
      <div class="sec-head"><div class="left rv"><Kicker text="From the Night" /></div></div>
      <Gallery items={item.gallery} />
      <div class="cs-next">
        <a href="/work/floydfest.html">&larr; FloydFest</a>
        <a href="/work/index.html">All case studies &rarr;</a>
      </div>
    </div>
  </section>

  <QuoteCta compact />

  <Footer />
</Layout>

<style>
  /* Prev/next case-study nav (source: main.css `.cs-next`, remapped
     --teal -> --glow-teal). */
  .cs-next {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    border-top: 1px solid rgba(63, 167, 150, 0.3);
    padding-top: 26px;
    margin-top: 16px;
  }
  .cs-next a {
    color: var(--glow-teal);
    font-weight: 600;
    text-decoration: none;
  }
</style>
