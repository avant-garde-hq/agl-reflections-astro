---
interface Props {
  href: string;
  variant?: 'coral' | 'ghost';
  class?: string;
}

const { href, variant = 'coral', class: cls = '' } = Astro.props;
---

<a class={`btn btn-${variant} ${cls}`} href={href}><slot /></a>

{/* .btn/.btn-coral/.btn-ghost live globally in src/styles/base.css so every
    page gets them, including pages (e.g. quote.astro) that hand-write
    class="btn btn-coral" markup without importing this component. */}
