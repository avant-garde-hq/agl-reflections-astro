---
// The "Through the Years" mile-marker grid on the about page. Unlike
// PathCards (Task 8), which had its `01`/`02`/`03` numbering stripped because
// those were parallel, unordered options, this component KEEPS its year
// markers on purpose — a timeline is a genuine chronological sequence, and
// the year is the whole point of each entry.
//
// Ported from agl-reflections-website/about.html lines 128-137 (`.tl-grid`)
// and assets/css/main.css lines 580-587 + the 1080px/620px responsive rules
// (lines 611, 613), hex colors swapped for the Task 2 CSS custom properties
// (--teal -> --glow-teal, --coral -> --gel-coral, --sand-dim -> --paper-dim,
// --hair -> --hairline, --panel -> --deck). The one `rgba(63,167,150,.25)`
// border doesn't match any existing token exactly, so it's kept literal.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface TimelineEntry {
  year: string;
  title: string;
  body: string;
  image?: ImageMetadata;
  imageAlt?: string;
  coral?: boolean;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<div class="tl-grid">
  {entries.map((e) => (
    <div class:list={['tl', { coral: e.coral }]}>
      <span class="yr">{e.year}</span>
      <h3>{e.title}</h3>
      <p>{e.body}</p>
      {e.image && (
        <div class="tl-img">
          <Image src={e.image} alt={e.imageAlt ?? ''} loading="lazy" />
        </div>
      )}
    </div>
  ))}
</div>

<style>
  .tl-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(22px, 2.6vw, 40px) clamp(20px, 2.5vw, 36px);
  }
  .tl {
    padding: 24px 0 6px;
    border-top: 1px solid rgba(63, 167, 150, 0.25);
  }
  .tl .yr {
    font-family: var(--font-display);
    font-size: clamp(26px, 2.6vw, 38px);
    line-height: 1;
    color: var(--glow-teal);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .tl.coral .yr {
    color: var(--gel-coral);
  }
  .tl h3 {
    font-size: 15.5px;
    margin: 12px 0 8px;
    letter-spacing: 0.03em;
  }
  .tl p {
    font-size: 13.5px;
    color: var(--paper-dim);
  }
  .tl .tl-img {
    margin-top: 14px;
    border: 1px solid var(--hairline);
    background: var(--deck);
  }
  .tl .tl-img :global(img) {
    width: 100%;
    height: auto;
  }
  @media (max-width: 1080px) {
    .tl-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 620px) {
    .tl-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
