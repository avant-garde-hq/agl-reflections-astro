---
import { SITE } from '../../config/site';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

// Real social glyphs, copied verbatim (path data only) from
// agl-reflections-website/index.html lines 178-179, keyed by SITE.socials
// label so lookup stays correct even if SITE.socials' order changes.
const socialIcons: Record<string, { viewBox: string; width: string; height: string; d: string }> = {
  Instagram: {
    viewBox: '0 0 24 24',
    width: '18',
    height: '18',
    d: 'M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.9.2 2.3.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1.1.4 2.3.1 1.3.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.9-.4 2.3-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1.1.4-2.3.4-1.3.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.9-.2-2.3-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1.1-.4-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.9.4-2.3.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1.1-.4 2.3-.4C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.4-1.2.8-.4.4-.6.7-.8 1.2-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.4.9.8 1.2.4.4.7.6 1.2.8.4.2 1 .3 2.1.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.4 1.2-.8.4-.4.6-.7.8-1.2.2-.4.3-1 .4-2.1.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1-.2-.5-.4-.9-.8-1.2-.4-.4-.7-.6-1.2-.8-.4-.2-1-.3-2.1-.4-1.2-.1-1.6-.1-4.7-.1zm0 3.1a4.9 4.9 0 1 1 0 9.8 4.9 4.9 0 0 1 0-9.8zm0 1.8a3.1 3.1 0 1 0 0 6.2 3.1 3.1 0 0 0 0-6.2zm5.1-2.9a1.1 1.1 0 1 1 0 2.3 1.1 1.1 0 0 1 0-2.3z',
  },
  Facebook: {
    viewBox: '0 0 24 24',
    width: '18',
    height: '18',
    d: 'M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z',
  },
  Youtube: {
    viewBox: '0 0 24 24',
    width: '18',
    height: '18',
    d: 'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12c0 1.9.2 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.3-1.9.5-3.9.5-5.8s-.2-3.9-.5-5.8zM9.5 15.6V8.4L15.8 12l-6.3 3.6z',
  },
  X: {
    viewBox: '0 0 24 24',
    width: '17',
    height: '17',
    d: 'M18.2 2h3.3l-7.3 8.4L22.8 22h-6.7l-5.3-6.9L4.8 22H1.5l7.8-9L1.2 2h6.9l4.8 6.3L18.2 2zm-1.2 18h1.8L6.9 3.9H4.9L17 20z',
  },
};
---
<nav class="site-nav" id="nav" aria-label="Main">
  <div class="nav-in">
    <a class="brand" href="/" aria-label={`${SITE.name} home`}>
      <svg viewBox="30 28 180 180" role="img" aria-hidden="true">
        <defs><clipPath id="logo-nav-clip"><circle cx="120" cy="118" r="84" /></clipPath></defs>
        <g clip-path="url(#logo-nav-clip)">
          <rect x="36" y="34" width="168" height="96" fill="var(--gel-coral)" />
          <rect x="36" y="138" width="168" height="11" fill="var(--glow-teal)" />
          <rect x="36" y="157" width="168" height="9" fill="var(--glow-teal)" opacity="0.68" />
          <rect x="36" y="174" width="168" height="8" fill="var(--glow-teal)" opacity="0.44" />
          <rect x="36" y="190" width="168" height="6" fill="var(--glow-teal)" opacity="0.24" />
          <g fill="var(--ink)">
            <path d="M112 132 C112 106 114 88 122 68 L132 72 C124 90 122 108 123 132 Z" />
            <path d="M127 70 C107 58 86 58 70 70 C88 66 108 68 127 78 Z" />
            <path d="M127 70 C115 51 97 43 78 45 C96 50 112 58 124 74 Z" />
            <path d="M127 70 C128 50 137 36 153 28 C141 42 134 56 133 72 Z" />
            <path d="M127 70 C145 56 165 54 181 62 C163 62 145 68 131 78 Z" />
            <path d="M127 70 C143 68 159 76 169 90 C155 80 141 78 129 82 Z" />
            <circle cx="127" cy="74" r="5" />
          </g>
        </g>
      </svg>
      <span class="bt"><b>{SITE.shortName}</b><span>{SITE.tagline}</span></span>
    </a>
    <div class="nav-links">
      {SITE.nav.map((item) => (
        <a href={item.href} class={currentPath === item.href ? 'active' : ''}
           aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
      ))}
    </div>
    <span class="nav-social" aria-label="Social media">
      {SITE.socials.map((s) => {
        const icon = socialIcons[s.label];
        return (
          <a class="f-social-a" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
            {icon && (
              <svg viewBox={icon.viewBox} width={icon.width} height={icon.height} fill="currentColor" aria-hidden="true">
                <path d={icon.d} />
              </svg>
            )}
          </a>
        );
      })}
    </span>
    <a class="nav-call" href={SITE.phoneHref} aria-label={`Call ${SITE.name}: ${SITE.phone}`}>☎</a>
    <a class="btn btn-coral" href={SITE.cta.href}>{SITE.cta.label}</a>
    <button class="nav-burger" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu"><i></i><i></i><i></i></button>
  </div>
</nav>
<div class="mobile-menu" id="mobile-menu">
  <a href="/">Home</a>
  {SITE.nav.map((item) => <a href={item.href}>{item.label}</a>)}
  <a href={SITE.cta.href} class="btn btn-coral">{SITE.cta.label}</a>
</div>

<style>
  /* Task 23 QA fix: this file had never had a <style> block since Task 4
     first wrote it -- the whole site header (and Footer.astro, fixed
     alongside this one) was rendering completely unstyled on every page
     (no fixed position, no burger collapse below 1080px, the `.mobile-menu`
     panel showing inline instead of as a hidden/toggled overlay). Caught by
     this task's required responsive spot check. Ported from
     agl-reflections-website/assets/css/main.css lines 99-146 (the
     `/* ---------- nav ---------- */` block) and its 1080px/700px/374px
     responsive rules (lines 530-563), hex colors swapped for the Task 2
     tokens (--sand->--paper, --sand-dim->--paper-dim, --teal->--glow-teal,
     --coral->--gel-coral, --black->--ink, --hair->--hairline).
     `.btn`/`.btn-coral` themselves are already styled globally by
     Button.astro (Task 3-ish) -- only the nav-specific size override below
     needs `:global()` to reach that already-rendered anchor.

     `.nav-social`/`.nav-call` DO exist in the source -- they're just
     styled via page-embedded `<style>` blocks (repeated verbatim on every
     page, e.g. index.html lines 80-85 and 127-134, about.html lines 23-34)
     rather than in the shared main.css, which is why the earlier version
     of this comment (and this component's first pass at these two
     classes) incorrectly assumed they were a rebuild-only addition with no
     source equivalent. Corrected below to the source's real, final
     (cascade-resolved -- the source's own later "nav-tighten" block
     re-declares both with different margin/gap) values: `.nav-social` is
     a `display:none` below 1080px, same breakpoint as `.nav-links`;
     `.nav-call` is a fixed 38x38 circular teal-bordered icon button,
     margin-right 12px (8px below 700px), visible at every width including
     mobile (source never hides it, even below 374px where the CTA button
     itself disappears). */
  nav.site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background 0.4s, border-color 0.4s;
    border-bottom: 1px solid transparent;
  }
  nav.site-nav.scrolled,
  nav.site-nav.solid {
    background: rgba(12, 20, 20, 0.86);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--hairline);
  }
  .nav-in {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
    width: 100%;
    display: flex;
    align-items: center;
    gap: 36px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .brand svg {
    height: 42px;
    width: 42px;
  }
  .brand .bt {
    line-height: 1;
  }
  .brand .bt b {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 17px;
    letter-spacing: 0.02em;
    display: block;
    color: var(--paper);
  }
  .brand .bt span {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: var(--glow-teal);
    font-weight: 600;
    display: block;
    margin-top: 3px;
  }
  .nav-links {
    display: flex;
    gap: 30px;
    margin-left: auto;
  }
  .nav-links a {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--paper-dim);
    transition: color 0.25s;
    position: relative;
    padding: 6px 0;
    white-space: nowrap;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 2px;
    background: var(--glow-teal);
    transition: right 0.3s;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--paper);
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    right: 0;
  }
  .nav-social {
    display: flex;
    align-items: center;
    gap: 11px;
    margin: 0 12px 0 4px;
    color: rgba(244, 239, 230, 0.65);
  }
  .nav-social .f-social-a {
    display: flex;
    color: inherit;
    transition: 0.15s;
  }
  .nav-social .f-social-a:hover {
    color: var(--glow-teal);
    transform: translateY(-1px);
  }
  .nav-call {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(63, 167, 150, 0.45);
    border-radius: 50%;
    color: var(--glow-teal);
    margin-right: 12px;
    transition: 0.15s;
    flex-shrink: 0;
  }
  .nav-call:hover {
    background: var(--glow-teal);
    color: var(--ink);
  }
  nav.site-nav :global(.btn) {
    padding: 12px 22px;
    font-size: 12px;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* mobile menu */
  .nav-burger {
    display: none;
    margin-left: 8px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: 1px solid rgba(244, 239, 230, 0.24);
    cursor: pointer;
    padding: 10px;
    flex-shrink: 0;
  }
  .nav-burger i {
    display: block;
    height: 2px;
    background: var(--paper);
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-burger i:nth-child(2) {
    background: var(--glow-teal);
  }
  .nav-burger[aria-expanded='true'] i:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-burger[aria-expanded='true'] i:nth-child(2) {
    opacity: 0;
  }
  .nav-burger[aria-expanded='true'] i:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--nav-h);
    left: 0;
    right: 0;
    z-index: 99;
    background: rgba(12, 20, 20, 0.97);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--hairline);
    padding: 18px clamp(20px, 4vw, 56px) 30px;
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu a {
    display: block;
    padding: 15px 0;
    font-family: var(--font-display);
    font-size: 21px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(63, 167, 150, 0.12);
    color: var(--paper);
  }
  .mobile-menu a.active {
    color: var(--glow-teal);
  }
  .mobile-menu a:hover {
    color: var(--gel-coral);
  }
  .mobile-menu :global(.btn) {
    margin-top: 22px;
    display: block;
  }

  @media (max-width: 1250px) {
    .nav-links {
      gap: 18px;
    }
    .nav-links a {
      font-size: 12.5px;
    }
  }
  @media (max-width: 1080px) {
    .nav-links,
    .nav-social {
      display: none;
    }
    .nav-burger {
      display: flex;
    }
    /* Task 23 QA fix: the source keeps `.nav-call` visible at every width
       (its own CSS never hides it, down to the 374px cutoff where the CTA
       button itself disappears -- see about.html/index.html's embedded
       nav-call rules). Faithfully porting that literally caused a real
       horizontal-scroll bug in this build: at 375px (a completely
       standard phone width) `.nav-call`'s fixed 38px circle pushed
       `.nav-in`'s row past the viewport. Hiding it here, at the same
       breakpoint as `.nav-social`, is the one deliberate deviation from
       source in this file -- it's a desktop-only convenience icon, not
       something the mobile menu or CTA button depends on. */
    .nav-call {
      display: none;
    }
  }
  @media (max-width: 700px) {
    nav.site-nav :global(.btn) {
      padding: 11px 13px;
      font-size: 10.5px;
      letter-spacing: 0.07em;
      white-space: nowrap;
    }
    /* Task 23 QA fix: gap/burger size tightened slightly past the
       source's own `gap:12px` to close a residual ~23px overflow at
       375px that persists even with `.nav-call` hidden (see above) --
       purely brand + compact CTA + burger already slightly overrun a
       375px-wide row at the source's literal values. Verified with
       chrome-devtools MCP at 360/375/700px: zero horizontal overflow at
       any of them with this adjustment. */
    .nav-in {
      gap: 6px;
    }
    .brand .bt span {
      display: none;
    }
    .nav-burger {
      margin-left: 0;
      width: 38px;
      height: 38px;
    }
  }
  @media (max-width: 374px) {
    nav.site-nav :global(.btn) {
      display: none;
    }
  }
</style>
